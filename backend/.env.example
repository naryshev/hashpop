# PostgreSQL (use this with Docker, or your own DB URL)
DATABASE_URL=postgres://hedera:hedera@localhost:5432/marketplace
# Mirror node (no key needed)
MIRROR_URL=https://testnet.mirrornode.hedera.com
# Paste after running: npm run deploy:testnet
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
AUCTION_HOUSE_ADDRESS=0x0000000000000000000000000000000000000000
# Hedera JSON-RPC (testnet)
HEDERA_RPC_URL=https://testnet.hashio.io/api
# Relayer wallet private key (ECDSA) – must hold HBAR to relay ED25519 txs
RELAYER_PRIVATE_KEY=
PORT=4000
LOG_LEVEL=info
