# ─── API ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Hedera network ───────────────────────────────────────
# Set to mainnet to use real HBAR (omit or leave unset for testnet)
# NEXT_PUBLIC_HEDERA_NETWORK=mainnet
NEXT_PUBLIC_HEDERA_NETWORK=testnet    # or: mainnet
# Hedera RPC. For mainnet use https://mainnet.hashio.io/api
NEXT_PUBLIC_HEDERA_RPC=https://testnet.hashio.io/api               # leave blank to use default Hashio endpoint

# ─── Deployed contract addresses ──────────────────────────
# Must match the addresses in backend/.env exactly
NEXT_PUBLIC_MARKETPLACE_ADDRESS=
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_AUCTION_HOUSE_ADDRESS=

# ─── HashPack / WalletConnect ─────────────────────────────
# Get a project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ─── Price feed (optional) ────────────────────────────────
# Leave blank to disable live HBAR/USD conversion
NEXT_PUBLIC_HBAR_USD=
# Optional feature flags (UI guards for optional modules)
NEXT_PUBLIC_FEATURE_OFFERS=true
NEXT_PUBLIC_FEATURE_MESSAGING_HCS_SEAM=true
NEXT_PUBLIC_FEATURE_RATINGS=true