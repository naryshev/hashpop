# ─── Server ───────────────────────────────────────────────
PORT=4000
LOG_LEVEL=info                        # trace | debug | info | warn | error
CORS_ORIGIN=https://hashpop.io,https://www.hashpop.io,https://hashpop.vercel.app     # frontend URL in prod: https://yourdomain.com

# ─── Database ─────────────────────────────────────────────
# On Railway, reference the Postgres service: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Hedera network ───────────────────────────────────────
HEDERA_RPC_URL=https://testnet.hashio.io/api   # mainnet: https://mainnet.hashio.io/api
MIRROR_URL=https://testnet.mirrornode.hedera.com

# ─── Deployed contract addresses ──────────────────────────
MARKETPLACE_ADDRESS=
ESCROW_ADDRESS=
AUCTION_HOUSE_ADDRESS=


# ─── Settlement engine (escrow keeper / EscrowV2 arbiter) ─
# Any funded key works for v1 timeout keeping; in v2 mode this key must hold
# ARBITER_ROLE on EscrowV2. Set ESCROW_V2=true when pointing at EscrowV2.
ESCROW_ARBITER_KEY=
ESCROW_V2=false
SETTLEMENT_INTERVAL_MS=60000

# ─── PII encryption ───────────────────────────────────────
# Encrypts buyer shipping addresses at rest (AES-256-GCM). Without this key
# the API refuses to store addresses, so checkout requires it in production.
# Generate: openssl rand -hex 32
SHIPPING_ADDRESS_KEY=

# ─── ED25519 relay signer (ECDSA account) ─────────────────
# Generate a fresh ECDSA account — never reuse a personal wallet key
RELAYER_ACCOUNT_ID=0.0.8253766
RELAYER_PRIVATE_KEY=

# ─── Image storage (S3-compatible) ────────────────────────
S3_ENDPOINT=https://e1b8cd26fe911106493a6cf096d8491b.r2.cloudflarestorage.com  # or your R2/MinIO endpoint
S3_REGION=auto
S3_BUCKET=hashpop-images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://pub-cb4b891f72b04e65a9b62a61fa3425a8.r2.dev

# ─── Frontend URL (used in emails / links generated server-side) ──
NEXT_PUBLIC_APP_URL=https://hashpop.io

# ─── Discord reporting (optional) ─────────────────────────
DISCORD_REPORT_WEBHOOK_URL=
DISCORD_REPORT_MENTION_ROLE_ID=

