generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id                 String   @id
  seller             String
  buyer              String?
  price              String
  status             String
  requireEscrow      Boolean  @default(false)
  txHash             String?
  trackingNumber     String?
  trackingCarrier    String?
    onChainConfirmed  Boolean @default(false)
  shippedAt          DateTime?
  exchangeConfirmedAt DateTime?
  title              String?
  subtitle           String?
  description        String?
  category           String?
  condition          String?
  yearOfProduction   String?
  originalBox        String?
  originalPapers     String?
  imageUrl           String?
  mediaUrls          String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  sales              Sale[]
}

model Auction {
  id                 String   @id
  seller             String
  reservePrice       String
  startTime          BigInt
  endTime            BigInt
  status             String
  title              String?
  subtitle           String?
  description        String?
  imageUrl           String?
  mediaUrls          String[] @default([])
  condition          String?
  yearOfProduction   String?
  originalBox        String?
  originalPapers     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  bids               Bid[]
  sales              Sale[]
}

model Bid {
  id        String   @id
  auctionId String
  bidder    String
  amount    String
  timestamp BigInt
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id])
}

model Sale {
  id        String   @id
  listingId String?
  auctionId String?
  buyer     String
  seller    String
  amount    String
  txHash    String?
  createdAt DateTime @default(now())
  listing   Listing? @relation(fields: [listingId], references: [id])
  auction   Auction? @relation(fields: [auctionId], references: [id])
    @@index([listingId])
      @@index([buyer])
}

model User {
  id                    String   @id
  address               String   @unique
  publicKey             String?
  profileImageUrl       String?
  totalSales            Int      @default(0)
  successfulCompletions Int      @default(0)
  refunds               Int      @default(0)
  timeouts              Int      @default(0)
  reputationScore       Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Rating {
  id              String   @id @default(cuid())
  reviewerAddress String
  ratedAddress    String
  saleId          String
  listingId       String?
  auctionId       String?
  score           Int
  comment         String?
  createdAt       DateTime @default(now())

  @@index([ratedAddress])
  @@index([reviewerAddress])
  @@unique([reviewerAddress, saleId])
}

model Message {
  id          String   @id @default(cuid())
  fromAddress String
  toAddress   String
  body        String
  listingId   String?
  encrypted   Boolean  @default(false)
  nonce       String?
  type        String   @default("message") // "message" | "offer"
  offerAmount String?
  offerStatus String?  // "pending" | "accepted" | "declined"
  createdAt   DateTime @default(now())
}

model ConversationRead {
  id           String   @id @default(cuid())
  address      String
  otherAddress String
  listingId    String   @default("")
  lastReadAt   DateTime @default(now())
  @@unique([address, otherAddress, listingId])
  @@index([address])
}

model WishlistItem {
  id          String   @id @default(cuid())
  userAddress String
  itemId      String
  itemType    String   // "listing" | "auction"
  createdAt   DateTime @default(now())
  @@unique([userAddress, itemId])
  @@index([userAddress])
}
