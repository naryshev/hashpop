# Backend API URL (sync-listing, listings, relay). Default: http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Hedera RPC. For mainnet use https://mainnet.hashio.io/api
NEXT_PUBLIC_HEDERA_RPC=https://testnet.hashio.io/api
# Set to mainnet to use real HBAR (omit or leave unset for testnet)
# NEXT_PUBLIC_HEDERA_NETWORK=mainnet
# Paste after running: npm run deploy:testnet
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ESCROW_ADDRESS=0xa0e53b74A32E93c5CdD4d73CF51B869CF511031F
NEXT_PUBLIC_AUCTION_HOUSE_ADDRESS=0x0000000000000000000000000000000000000000
# WalletConnect project ID (required for HashPack: get free ID at https://cloud.reown.com)
NEXT_PUBLIC_WC_PROJECT_ID=
# Optional: set true to force HashPack extension-only mode (no pairing modal fallback).
# If extension pairing fails in this mode, connect will fail instead of opening QR/deep-link modal.
# NEXT_PUBLIC_HASHPACK_EXTENSION_ONLY=true
# Optional: public app URL (for wallet "Send transaction" label; e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=
# Optional: HBAR/USD rate for display (e.g. 0.25). If unset, frontend fetches from CoinGecko.
NEXT_PUBLIC_HBAR_USD=
# Optional feature flags (UI guards for optional modules)
NEXT_PUBLIC_FEATURE_OFFERS=true
NEXT_PUBLIC_FEATURE_MESSAGING_HCS_SEAM=true
NEXT_PUBLIC_FEATURE_RATINGS=true
