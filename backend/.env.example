# PostgreSQL (use this with Docker, or your own DB URL)
DATABASE_URL=postgres://hedera:hedera@localhost:5432/marketplace
# Mirror node (no key needed)
MIRROR_URL=https://testnet.mirrornode.hedera.com
# Paste after running: npm run deploy:testnet
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
AUCTION_HOUSE_ADDRESS=0x0000000000000000000000000000000000000000
# Hedera JSON-RPC (testnet)
HEDERA_RPC_URL=https://testnet.hashio.io/api
# Relayer wallet private key (ECDSA) – must hold HBAR to relay ED25519 txs
RELAYER_PRIVATE_KEY=
PORT=4000
LOG_LEVEL=info
# Optional feature flags
#FEATURE_OFFERS=true
#FEATURE_HCS_SEAM=true
#FEATURE_RATINGS=true
# Frontend origin(s) for CORS. Comma-separated for multiple. Unset = localhost:3000 + 127.0.0.1:3000.
# For Vercel: set to your frontend URL, e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Optional: S3-compatible storage for listing images (e.g. AWS S3 or Cloudflare R2).
# If set, uploads go to the bucket and the returned URL uses S3_PUBLIC_URL. If unset, files are stored on disk.
# R2: endpoint https://<ACCOUNT_ID>.r2.cloudflarestorage.com, region auto
# S3_PUBLIC_URL=https://your-bucket.s3.region.amazonaws.com
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=   # optional; for R2 use https://<ACCOUNT_ID>.r2.cloudflarestorage.com
