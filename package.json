{
  "name": "hashpop",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=20.0.0 <=24.x"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start --parallel",
    "dev": "turbo run dev --parallel --continue",
    "compile": "hardhat compile",
    "test": "turbo run test",
    "test:contracts": "hardhat test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:testnet": "hardhat run deploy/deploy.ts --network hederaTestnet",
    "deploy:mainnet": "hardhat run deploy/deploy.ts --network hederaMainnet",
    "unpause:testnet": "hardhat run deploy/unpause.ts --network hederaTestnet",
    "unpause:mainnet": "hardhat run deploy/unpause.ts --network hederaMainnet",
    "authorize:escrow": "hardhat run deploy/authorize-escrow.ts --network hederaTestnet",
    "authorize:escrow:mainnet": "hardhat run deploy/authorize-escrow.ts --network hederaMainnet",
    "verify": "hardhat run deploy/verify.ts",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "db:seed": "npm run db:seed --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "dev:kill": "kill-port 4000",
    "dev:legacy": "(npm run dev:kill || node -e \"process.exit(0)\") && concurrently -k -n backend,frontend -c magenta,yellow \"npm run dev:backend\" \"wait-on tcp:4000 && npm run dev:frontend\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.3.0",
    "eslint-config-prettier": "^10.1.8",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.10",
    "kill-port": "^2.0.0",
    "prettier": "^3.8.1",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.2",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@vercel/analytics": "^1.6.1",
    "turbo": "^2.8.11"
  }
}
