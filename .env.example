# Deployer wallet for Hardhat networks (64 hex chars, with or without 0x).
# Preferred key name:
HEDERA_TESTNET_OPERATOR=your_private_key_here
# Backward-compatible fallback:
PRIVATE_KEY=your_private_key_here
# Public RPC - no signup needed
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
# Optional: deployment fee setting in basis points (default 300 = 3%)
PLATFORM_FEE_BPS=300
